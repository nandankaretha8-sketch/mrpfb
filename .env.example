# Application
APP_NAME=MRFX
DEBUG=false
API_V1_PREFIX=/api/v1
USE_SQLITE=False

# MySQL (Railway or remote)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

WP_DB_HOST=
WP_DB_PORT=3306
WP_DB_USER=
WP_DB_PASSWORD=
WP_DB_NAME=

# Security
API_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=

# Email (SMTP — external provider, not Railway)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=MRPFX
SMTP_TLS=true
ADMIN_EMAIL=

# Payments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# URLs
FRONTEND_URL=https://mrpfx.com
BACKEND_URL=

BCRYPT_ROUNDS=12
